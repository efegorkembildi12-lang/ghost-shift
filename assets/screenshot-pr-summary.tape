# Produces: assets/launch/cli-pr-summary.png

Output assets/launch/cli-pr-summary.png

Set Theme "Catppuccin Mocha"
Set FontSize 16
Set Width 860
Set Height 500
Set Padding 24
Set Shell "/tmp/vhs-shell.sh"
Set TypingSpeed 50ms
Set WaitTimeout 15s

Sleep 500ms
Type "ghostshift pr-summary"
Enter
Sleep 2s
