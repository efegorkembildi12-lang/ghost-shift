{
  "name": "ghostshift",
  "version": "1.0.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "ghostshift",
      "version": "1.0.0",
      "license": "AGPL-3.0-only",
      "workspaces": [
        "apps/*",
        "packages/*"
      ],
      "bin": {
        "ghostshift": "apps/cli/src/index.js",
        "ghostshift-preview": "apps/server/src/index.js"
      },
      "engines": {
        "node": ">=20.0.0",
        "npm": ">=10.0.0"
      }
    },
    "apps/cli": {
      "name": "@ghostshift/cli",
      "version": "1.0.0",
      "license": "AGPL-3.0-only",
      "bin": {
        "ghostshift": "src/index.js"
      }
    },
    "apps/server": {
      "name": "@ghostshift/server",
      "version": "1.0.0",
      "license": "AGPL-3.0-only",
      "bin": {
        "ghostshift-server": "src/index.js"
      }
    },
    "apps/ui": {
      "name": "@ghostshift/ui",
      "version": "1.0.0",
      "license": "AGPL-3.0-only"
    },
    "node_modules/@ghostshift/cli": {
      "resolved": "apps/cli",
      "link": true
    },
    "node_modules/@ghostshift/core": {
      "resolved": "packages/core",
      "link": true
    },
    "node_modules/@ghostshift/plugins": {
      "resolved": "packages/plugins",
      "link": true
    },
    "node_modules/@ghostshift/server": {
      "resolved": "apps/server",
      "link": true
    },
    "node_modules/@ghostshift/spec": {
      "resolved": "packages/spec",
      "link": true
    },
    "node_modules/@ghostshift/storage": {
      "resolved": "packages/storage",
      "link": true
    },
    "node_modules/@ghostshift/ui": {
      "resolved": "apps/ui",
      "link": true
    },
    "packages/core": {
      "name": "@ghostshift/core",
      "version": "1.0.0",
      "license": "AGPL-3.0-only"
    },
    "packages/plugins": {
      "name": "@ghostshift/plugins",
      "version": "1.0.0",
      "license": "AGPL-3.0-only"
    },
    "packages/spec": {
      "name": "@ghostshift/spec",
      "version": "1.0.0",
      "license": "Apache-2.0"
    },
    "packages/storage": {
      "name": "@ghostshift/storage",
      "version": "1.0.0",
      "license": "AGPL-3.0-only"
    }
  }
}
